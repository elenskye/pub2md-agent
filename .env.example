# LLM provider (any OpenAI-compatible API; DeepSeek by default)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Web search (used from Phase 3 for terminology research)
TAVILY_API_KEY=tvly-...

# Optional cost controls (defaults shown)
# MAX_TOKENS_PER_CALL=4096
# LLM_TEMPERATURE=0.3
# Prices in USD per 1M tokens, only for the end-of-run cost estimate
# PRICE_INPUT_PER_M=0.27
# PRICE_OUTPUT_PER_M=1.10
