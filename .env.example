# Select the active provider block below (deepseek / openai / openrouter).
# All providers are accessed through their OpenAI-compatible API.
LLM_PROVIDER=deepseek

DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_MODEL=
OPENAI_API_KEY=

OPENROUTER_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Web search for terminology research (Phase 3)
TAVILY_API_KEY=tvly-...

# Multimodal model for formula → LaTeX transcription (Phase 5, optional).
# Any OpenAI-compatible vision model works (e.g. via OpenRouter). When
# unset, formulas are kept as [formula] placeholders instead.
VLM_MODEL=
VLM_API_KEY=
VLM_BASE_URL=

# Observability (optional): set these to stream full LangChain/LangGraph
# traces to LangSmith — no code changes needed, langchain reads the env.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=pub2md-agent

# --- Web app (webapp/, 2.0) ---------------------------------------------
# Production: set DEBUG false, a long random SECRET_KEY, and your domain.
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_urlsafe(50))">
# DJANGO_ALLOWED_HOSTS=pub2md.duckdns.org
# DJANGO_CSRF_TRUSTED_ORIGINS=https://pub2md.duckdns.org
# Account names for `manage.py rotate_accounts` (default guest1,guest2)
# PUB2MD_ACCOUNTS=guest1,guest2
# Guards (defaults shown)
# PUB2MD_MAX_UPLOAD_MB=25
# PUB2MD_MAX_PDF_PAGES=100
# PUB2MD_MONTHLY_BUDGET_USD=5.0
# PUB2MD_JOB_RETENTION_DAYS=7
# PUB2MD_JOB_STALE_MINUTES=45

# Optional cost controls (defaults shown)
# MAX_TOKENS_PER_CALL=4096
# LLM_TEMPERATURE=0.3
# Prices in USD per 1M tokens, only for the end-of-run cost estimate
# PRICE_INPUT_PER_M=0.27
# PRICE_OUTPUT_PER_M=1.10
