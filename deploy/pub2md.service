# systemd unit for the Pub2MD web app.
# Install: sudo cp deploy/pub2md.service /etc/systemd/system/
#          sudo systemctl daemon-reload && sudo systemctl enable --now pub2md
#
# IMPORTANT: exactly ONE gunicorn worker. Background jobs run in an
# in-process thread pool and the monthly-budget check assumes a single
# process; scale with --threads, not --workers.

[Unit]
Description=Pub2MD Agent web app
After=network.target

[Service]
User=pub2md
Group=pub2md
WorkingDirectory=/opt/pub2md-agent/webapp
Environment=DJANGO_SETTINGS_MODULE=config.settings
ExecStart=/opt/pub2md-agent/.venv/bin/gunicorn config.wsgi:application \
    --workers 1 --threads 8 --timeout 120 --bind 127.0.0.1:8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
